{
  dataset_id: "industrial_conus_2022",
  dataset_type: "modeled",
  data_source: "industrial",
  sector_description: "industrial",
  description: "CONUS 2022 Industrial data",
  origin_creator: "",
  origin_organization: "LBNL",
  origin_contributors: [
    "Sarah Smith",
    "Samanvitha Murthy",
  ],
  origin_project: "",
  origin_date: "",
  origin_version: "",
  source: "",
  data_classification: "low",
  tags: [
    "industrial",
  ],
  trivial_dimensions: [
    "sector",
    "subsector",
    "weather_year",
    "model_year",
    "scenario",
  ],
  use_project_geography_time_zone: true,
  data_schema: {
    table_format: {
      format_type: "pivoted",
      pivoted_dimension_type: "metric",
    },
    data_schema_type: "one_table",
  },
  dimensions: [
    {
      "class": "State",
      type: "geography",
      name: "States Abbreviated",
      display_name: "states",
      file: "dimensions/industrial_states.csv",
      description: "Industrial States",
    },
    {
      "class": "EnergyEndUse",
      type: "metric",
      name: "Industrial End Uses",
      display_name: "ind_end_uses",
      file: "dimensions/industrial_enduses.csv",
      description: "Industrial End Uses",
    },
    {
      "class": "Time",
      type: "time",
      name: "Local-time-2022-indexed",
      display_name: "time",
      time_type: "indexed",
      index_ranges: [
	{
          start: 0,
          end: 8759,
	  interval: 1,
        },
      ],
      ranges: [
        {
          start: "2018-01-01 00:00:00",
          end: "2018-12-31 23:00:00",
        },
      ],
      str_format: "%Y-%m-%d %H:%M:%S",
      frequency: "P0DT1H0M0.000000S",
      timezone: "LocalStandard",
      time_interval_type: "period_ending",
      measurement_type: "total",
      data_adjustment: {
        daylight_saving_adjustment: 
          {
            spring_forward_hour: "drop",
            fall_back_hour: "interpolate",
          },
      },
      description: "Industrial time, indexed, stitched from representative diurnal profiles in county local standard time, data and timestamps need adjustment to local prevailing time",
    },
  ],
}
